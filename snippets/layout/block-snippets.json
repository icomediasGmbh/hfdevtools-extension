{
    "Template": {
        "scope": "html",
        "prefix": "hf-block",
        "body": ["<div id=\"${1:id}\"", "    data-hf-block", "    $2", "</div>"],
        "description": "Creates an empty block container"
    },

    "Condition": {
        "scope": "html",
        "prefix": "hf-condition",
        "body": [
            "<div id=\"${1:id}\"",
            "    data-hf-control=\"HFWinJSCtrl.Condition\"",
            "    data-hf-condition='{",
            "        \"op\": \"and\",",
            "        \"cond\": [{",
            "            \"type\": \"$2\",",
            "            \"id\": \"$3\",",
            "            \"val\": \"$4\"",
            "        }],",
            "        \"else\": \"${5:invisible}\"",
            "    }'>",
            "    $6",
            "</div>"
        ],
        "description": "Creates a block, area, tab, condition definition"
    },

    "PageTemplate": {
        "scope": "html",
        "prefix": "hf-pagetemplate",
        "body": ["<li data-hf-title=\"$1\">", "    <ol>", "        $2", "    </ol>", "</li>"],
        "description": "Creates a Page template"
    },

    "TabTemplate": {
        "scope": "html",
        "prefix": "hf-tabtemplate",
        "body": ["<li data-hf-title=\"$1\">", "    $2", "</li>"],
        "description": "Creates a Tab template"
    },

    "TabCaption": {
        "scope": "html",
        "prefix": "hf-tabcaption",
        "body": ["data-hf-caption=\"$1\"", "data-hf-subcaption=\"$2\""],
        "description": "Creates a Tab caption"
    },

    "BlockCaption": {
        "scope": "html",
        "prefix": "hf-blockcaption",
        "body": ["data-hf-caption=\"$1\"", "data-hf-subcaption=\"$2\"", "data-hf-separator=\"${3: bottom}\""],
        "description": "Creates a Block caption"
    },

    "FullWidthBlock": {
        "scope": "html",
        "prefix": "hf-fullwidth-block",
        "body": ["<a href=\"$1\"", "    data-hf-fullWidth=\"true\"></a>"],
        "description": "Creates a FullWidth block definition"
    },

    "HeaderTitleTemplate": {
        "scope": "html",
        "prefix": "hf-headertitletemplate",
        "body": [
            "<div data-hf-template=\"FormHeaderTitle\">",
            "    <span class=\"page-label\">",
            "        <span data-hf-bind=\"innerHTML: data.PageTitle\"></span>",
            "    </span>",
            "    <i class=\"fa-regular fa-angle-double-left\"></i>",
            "    <span class=\"form-title\">",
            "        <span data-hf-bind=\"innerHTML: data.FormTitle\"></span>",
            "    </span>",
            "</div>"
        ],
        "description": "Creates a HeaderTitleTemplate element"
    },

    "TitleTemplate": {
        "scope": "html",
        "prefix": "hf-titletemplate",
        "body": [
            "<div data-hf-template=\"FormTitle\">",
            "    <h1>",
            "        <span class=\"colon\" data-hf-bind=\"innerHTML: data.FormTitle\"></span>",
            "    </h1>",
            "    <h2 data-hf-control=\"Spacer\">",
            "        $1",
            "    <h2>",
            "</div>"
        ],
        "description": "Creates a TitleTemplate element"
    },

    "ListTemplate": {
        "scope": "html",
        "prefix": "hf-listtemplate",
        "body": [
            "<div id=\"listTemplate\"",
            "    data-hf-template=\"FormList\"",
            "    data-hf-options=\"{",
            "        img: 'base-80x80.svg',",
            "        showMainImage: true",
            "    }\">",
            "    <div class=\"row-1\">",
            "        <h3 data-hf-control=\"HFWinJSCtrl.Spacer\"",
            "            class=\"win-type-ellipsis\">",
            "            $1",
            "        </h3>",
            "    </div>",
            "    <div class=\"row-2\">",
            "        <h4 data-hf-control=\"HFWinJSCtrl.Spacer\"",
            "            class=\"win-type-ellipsis\">",
            "            $2",
            "        </h4>",
            "    </div>",
            "    <div class=\"row-3\">",
            "        <h5 data-hf-control=\"HFWinJSCtrl.Spacer\"",
            "            class=\"win-type-ellipsis\">",
            "            $3",
            "        </h5>",
            "    </div>",
            "</div>"
        ],
        "description": "Creates a listTemplate element"
    },

    "ObserveField": {
        "scope": "html",
        "prefix": "hf-observefield",
        "body": [
            "<span data-hf-control=\"HFWinJSCtrl.ObserveField\"",
            "    data-hf-options=\"{",
            "        fieldId: '${1:list_field}',",
            "    }\"></span>"
        ],
        "description": "Creates a ObserveField element"
    },

    "DateFormater": {
        "scope": "html",
        "prefix": "hf-dateformater",
        "body": [
            "<span data-hf-bind=\"textContent: listData.${1:list_field}\"",
            "    data-hf-control=\"HFWinJSCtrl.DateFormater\"",
            "    data-hf-options=\"{ ",
            "        dateFormat: '',",
            "        timeFormat: '',",
            "        dateOnly: false,",
            "        timeOnly: false,",
            "    }\"",
            "></span>"
        ],
        "description": "Creates a DateFormater element"
    },

    "TextContent": {
        "scope": "html",
        "prefix": "hf-textcontent",
        "body": ["<span data-hf-bind=\"textContent: listData.${1:list_field}\"></span>"],
        "description": "Creates a text content element"
    },

    "InitializerVariable": {
        "scope": "html",
        "prefix": "hf-initializer",
        "body": [
            "<var data-hf-name=\"Initializer\"",
            "    data-hf-rendered=\"HFFormdefinition.${1:Namespace}.onRendered\"",
            "    data-hf-view-rendered=\"HFFormdefinition.${1:Namespace}.onViewRendered\"",
            "    data-hf-disposed=\"HFFormdefinition.${1:Namespace}.onDisposed\"></var>"
        ],
        "description": "Creates an initializer variable"
    }
}
